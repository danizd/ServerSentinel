# ServerSentinel Configuration
# Copy to .env and customize

# === Honeypot Ports ===
HTTP_PORT=80
SSH_PORT=2222
FTP_PORT=2121
MYSQL_PORT=3306
BLOG_PORT=8080

# === LLM Configuration ===
OLLAMA_URL=http://localhost:11434
LLM_MODEL=qwen2.5:1.5b
LLM_TIMEOUT_MS=5000

# === Database ===
DB_PATH=./data/sentinel.db
DATA_RETENTION_DAYS=90

# === Rate Limiting ===
RATE_LIMIT_RPM=60

# === Simulation ===
SIMULATION_MODE=full

# === Admin Credentials (HTTP honeypot) ===
ADMIN_USER=admin
ADMIN_PASS=admin
